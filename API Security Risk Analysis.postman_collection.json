  "item": [
    {
      "name": "ReqRes API Tests",
      "item": [
        {
          "name": "List Users (Auth Check)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"SECURITY: Response time is acceptable (< 2000ms)\", function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);",
                  "});",
                  "",
                  "pm.test(\"SECURITY: Check for sensitive data exposure in response\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    var responseStr = JSON.stringify(jsonData);",
                  "    pm.expect(responseStr).to.not.include(\"password\");",
                  "    pm.expect(responseStr).to.not.include(\"ssn\");",
                  "    pm.expect(responseStr).to.not.include(\"credit_card\");",
                  "});",
                  "",
                  "pm.test(\"SECURITY: X-Content-Type-Options header present\", function () {",
                  "    pm.expect(pm.response.headers.get(\"X-Content-Type-Options\")).to.not.be.undefined;",
                  "});",
                  "",
                  "pm.test(\"SECURITY: X-Frame-Options header present\", function () {",
                  "    pm.expect(pm.response.headers.get(\"X-Frame-Options\")).to.not.be.undefined;",
                  "});",
                  "",
                  "pm.test(\"SECURITY: Strict-Transport-Security header present\", function () {",
                  "    pm.expect(pm.response.headers.get(\"Strict-Transport-Security\")).to.not.be.undefined;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-api-key",
                "value": "free_user_3DFNbNe2kQwMEOpLK3WrUJetRgO"
              }
            ],
            "url": {
              "raw": "https://reqres.in/api/users",
              "protocol": "https",
              "host": [
                "reqres",
                "in"
              ],
              "path": [
                "api",
                "users"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Single User",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"SECURITY: Response does not expose internal IDs excessively\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data).to.have.property(\"id\");",
                  "    // Check no sensitive fields",
                  "    pm.expect(jsonData.data).to.not.have.property(\"password\");",
                  "    pm.expect(jsonData.data).to.not.have.property(\"token\");",
                  "});",
                  "",
                  "pm.test(\"SECURITY: Content-Type header is application/json\", function () {",
                  "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-api-key",
                "value": "free_user_3DFNbNe2kQwMEOpLK3WrUJetRgO"
              }
            ],
            "url": {
              "raw": "https://reqres.in/api/users/1",
              "protocol": "https",
              "host": [
                "reqres",
                "in"
              ],
              "path": [
                "api",
                "users",
                "1"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Access Non-Existent User (IDOR Check)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"SECURITY: Non-existent resource returns 404 (not 200 or 500)\", function () {",
                  "    pm.response.to.have.status(404);",
                  "});",
                  "",
                  "pm.test(\"SECURITY: Error response does not leak stack trace or internal info\", function () {",
                  "    var responseText = pm.response.text();",
                  "    pm.expect(responseText).to.not.include(\"stack\");",
                  "    pm.expect(responseText).to.not.include(\"Exception\");",
                  "    pm.expect(responseText).to.not.include(\"SQL\");",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-api-key",
                "value": "free_user_3DFNbNe2kQwMEOpLK3WrUJetRgO"
