        {
          "name": "Login - Weak Auth Check",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"SECURITY: Token is returned on login\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property(\"token\");",
                  "    pm.expect(jsonData.token).to.be.a(\"string\");",
                  "    pm.expect(jsonData.token.length).to.be.above(0);",
                  "});",
                  "",
                  "pm.test(\"SECURITY: Password not echoed back in response\", function () {",
                  "    var responseStr = pm.response.text();",
                  "    pm.expect(responseStr).to.not.include(\"cityslicka\");",
                  "});",
                  "",
                  "pm.test(\"SECURITY: Response does not expose sensitive auth details\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.not.have.property(\"password\");",
                  "    pm.expect(jsonData).to.not.have.property(\"secret\");",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "x-api-key",
                "value": "free_user_3DFNbNe2kQwMEOpLK3WrUJetRgO"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"eve.holt@reqres.in\",\n    \"password\": \"cityslicka\"\n}"
            },
            "url": {
              "raw": "https://reqres.in/api/login",
              "protocol": "https",
              "host": [
                "reqres",
                "in"
              ],
              "path": [
                "api",
                "login"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Login with Missing Password (Input Validation)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"SECURITY: Missing required fields returns 400 (not 500)\", function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([400, 422]);",
                  "});",
                  "",
                  "pm.test(\"SECURITY: Error message does not expose internal details\", function () {",
                  "    var responseText = pm.response.text();",
                  "    pm.expect(responseText).to.not.include(\"stack\");",
                  "    pm.expect(responseText).to.not.include(\"Exception\");",
                  "    pm.expect(responseText).to.not.include(\"undefined\");",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "x-api-key",
                "value": "free_user_3DFNbNe2kQwMEOpLK3WrUJetRgO"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"eve.holt@reqres.in\"\n}"
            },
            "url": {
              "raw": "https://reqres.in/api/login",
              "protocol": "https",
              "host": [
                "reqres",
                "in"
              ],
              "path": [
                "api",
                "login"
              ]
            }
          },
