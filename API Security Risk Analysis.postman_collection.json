        {
          "name": "Access Users Data (Data Exposure Check)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"SECURITY: Check for PII exposure in user data\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    var responseStr = JSON.stringify(jsonData);",
                  "    // JSONPlaceholder exposes email, address, phone - document as risk",
                  "    console.log(\"RISK: User PII exposed - emails, addresses, phone numbers accessible without auth\");",
                  "    pm.expect(jsonData[0]).to.have.property(\"email\");",
                  "    // Document that this is a risk",
                  "    console.log(\"RISK IDENTIFIED: User emails are publicly accessible: \" + jsonData[0].email);",
                  "});",
                  "",
                  "pm.test(\"SECURITY: No rate limiting headers present (document risk)\", function () {",
                  "    var rateLimitHeader = pm.response.headers.get(\"X-RateLimit-Limit\");",
                  "    if (!rateLimitHeader) {",
                  "        console.log(\"RISK: No rate limiting headers detected. API may be vulnerable to abuse.\");",
                  "    }",
                  "    // This is informational - we just document the finding",
                  "    pm.expect(true).to.be.true;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "https://jsonplaceholder.typicode.com/users",
              "protocol": "https",
