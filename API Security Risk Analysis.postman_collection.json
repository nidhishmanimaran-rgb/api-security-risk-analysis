              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"SECURITY: Unauthenticated POST accepted - HIGH RISK\", function () {",
                  "    // JSONPlaceholder accepts POST without auth - document this risk",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "    console.log(\"HIGH RISK: API allows creating resources without any authentication!\");",
                  "});",
                  "",
                  "pm.test(\"SECURITY: Response does not expose server internals\", function () {",
                  "    var responseText = pm.response.text();",
                  "    pm.expect(responseText).to.not.include(\"stack\");",
                  "    pm.expect(responseText).to.not.include(\"Exception\");",
