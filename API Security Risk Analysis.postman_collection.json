    {
      "name": "JSONPlaceholder API Tests",
      "item": [
        {
          "name": "List Posts (Open Endpoint Check)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"SECURITY: Endpoint is publicly accessible without auth (document risk)\", function () {",
                  "    // This test documents that the endpoint requires NO authentication - a security risk",
                  "    pm.response.to.have.status(200);",
                  "    console.log(\"RISK IDENTIFIED: This endpoint is unauthenticated. Anyone can access all posts data.\");",
                  "});",
                  "",
                  "pm.test(\"SECURITY: Check for excessive data exposure (too many records)\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    // JSONPlaceholder returns 100 posts - document this as a risk",
                  "    console.log(\"RISK: API returns \" + jsonData.length + \" records with no pagination limit enforced.\");",
                  "    pm.expect(jsonData).to.be.an(\"array\");",
                  "});",
                  "",
                  "pm.test(\"SECURITY: No sensitive headers exposed in response\", function () {",
                  "    pm.expect(pm.response.headers.get(\"X-Powered-By\")).to.be.null;",
                  "    pm.expect(pm.response.headers.get(\"Server\")).to.be.null;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "https://jsonplaceholder.typicode.com/posts",
              "protocol": "https",
              "host": [
                "jsonplaceholder",
                "typicode",
                "com"
              ],
              "path": [
                "posts"
              ]
            }
          },
          "response": []
        },
